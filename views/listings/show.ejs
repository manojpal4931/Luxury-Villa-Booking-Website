<% layout("/layouts/boilerplate") %>

<script>
const mapToken = "<%=process.env.MAP_TOKEN %>";
const listing = <%- JSON.stringify(listing) %>;

</script>

<div class="container mt-4">

  <div class="row justify-content-center">

    <div class="col-lg-8">

      <!-- LISTING CARD -->
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <img
          src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/800x400' %>"
          class="img-fluid"
          style="height: 400px; object-fit: cover;"
        >

        <div class="card-body p-4">

          <h3 class="fw-bold"><%= listing.title %></h3>

          <p class="text-muted mb-2">
            📍 <%= listing.location %>, <%= listing.country %>
          </p>

          <h5 class="mb-3">
            💰 ₹ <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %>
          </h5>
    <p>Owned by<i><%=listing.owner.username %> </i></p>
        <br>
          <p><%= listing.description %></p>

        </div>

      </div>

      <!-- BUTTONS -->
      <% if(currUser && listing.owner._id.equals(currUser.id))  {%>
             <div class="d-flex gap-2 mt-3">

        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark rounded-pill px-4">
          Edit
        </a>

        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
          <button class="btn btn-danger rounded-pill px-4">
            Delete
          </button>
        </form>
</div>

<% } %>


      <!-- REVIEW FORM -->
      <div class="mt-5">

        <h4 class="fw-bold mb-3">Leave a Review</h4>
  <% if(currUser) {%>
        <form action="/listings/<%= listing._id %>/reviews" method="POST">

          <div class="row g-3">

            <!-- rating -->
            <div class="col-md-6">
              <select name="review[rating]" class="form-select rounded-3" required>
                <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                <option value="4">⭐⭐⭐⭐ Very Good</option>
                <option value="3">⭐⭐⭐ Good</option>
                <option value="2">⭐⭐ Average</option>
                <option value="1">⭐ Poor</option>
              </select>
            </div>

            <!-- name -->
            <div class="col-md-6">
              <input type="text"
                name="review[name]"
                class="form-control rounded-3"
                placeholder="Your name"
                required>
            </div>

            <!-- comment -->
            <div class="col-12">
              <textarea
                name="review[comment]"
                class="form-control rounded-3"
                rows="3"
                placeholder="Write your review..."
                required></textarea>
            </div>

            <div class="col-12">
              <button class="btn btn-dark w-100 rounded-pill">
                Submit Review
              </button>
            </div>

          </div>

        </form>
    <%  }  %>

      </div>

      <!-- REVIEWS SECTION -->
      <div class="mt-5">

   
        <h4 class="fw-bold mb-3">Reviews</h4>

        <% if (listing.reviews && listing.reviews.length > 0) { %>

          <div class="row g-3">

            <% listing.reviews.forEach((review) => { %>

              <div class="col-md-6">

                <!-- 👇 THIS IS IMPORTANT FOR HOVER -->
                <div class="border rounded-4 p-3 shadow-sm h-100 review-card">

                  <div class="d-flex justify-content-between align-items-center">

                    <div class="fw-bold">
                      👤 <%= review.name %>
                    </div>

                    <div class="text-warning">
                      ⭐ <%= review.rating %>/5
                    </div>

                  </div>

                  <p class="mt-2 mb-3 text-muted">
                    <%= review.comment %>
                  </p>

                  <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-sm btn-outline-danger rounded-pill">
                      Delete
                    </button>
                  </form>

                </div>

              </div>

            <% }) %>

          </div>

        <% } else { %>

          <p class="text-muted">No reviews yet.</p>

        <% } %>

        <hr/>

      </div>
</div>

 <!-- mapbox implement -->

<div class="col-lg-8 mx-auto mb-4">
      <h3>Where you'll be</h3>
      <div id="map"></div>
      </div>
  </div>

</div>

<script src="/js/map.js"></script>